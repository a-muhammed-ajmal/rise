# ─────────────────────────────────────────────────────────────────────────────
# RISE — environment variables. Copy this file to .env.local and fill in values.
#   cp .env.example .env.local
# NEVER commit .env.local. Everything below is a placeholder — no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
# Supabase publishable (a.k.a. anon) key — the app reads PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Bypasses Row Level Security — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
VOYAGE_API_KEY=                 # optional — keyword ILIKE fallback runs when absent
# Signs the HMAC approval tokens that gate destructive AI tools. Long random string.
APPROVAL_HMAC_SECRET=

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=              # server-only
VAPID_SUBJECT=                  # e.g. mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Auth gate ───────────────────────────────────────────────────────────────
ALLOWED_USER_EMAIL=             # only this Google account may sign in

# ─── Cron (daily digest) ─────────────────────────────────────────────────────
CRON_SECRET=                    # random secret; also set it in Vercel env vars

# ─── MCP connector (Claude) ──────────────────────────────────────────────────
# Bearer token Claude Code must send to reach POST /api/mcp. Generate a long
# random string (e.g. `openssl rand -hex 32`). If unset, the MCP endpoint still
# works via OAuth but the static-token (Claude Code) path is disabled.
MCP_ACCESS_TOKEN=

# OAuth 2.1 for the claude.ai (web) & Claude Desktop native connector. Create one
# confidential client: pick any id and a long random secret, and paste the SAME
# two values into claude.ai → Connectors → Advanced settings. Requires migration
# 015_oauth.sql to be applied.
MCP_OAUTH_CLIENT_ID=
MCP_OAUTH_CLIENT_SECRET=
