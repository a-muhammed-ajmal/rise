{
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(npm run lint)",
      "Bash(npm run test:coverage)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git push*)",
      "Bash(git stash*)",
      "Bash(git branch*)"
    ],
    "deny": [
      "Bash(git reset --hard*)"
    ]
  },
  "hooks": {
    "PreToolUse": []
  }
}
