{
  "permissions": {
    "allow": ["Read", "Edit", "Bash(npm:*)", "Bash(git:*)"],
    "deny": ["Bash(git reset --hard*)"]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "command": "scripts/block-destructive.sh" }
    ],
    "PostToolUse": [
      { "matcher": "Write(*.ts,*.tsx,*.js,*.jsx)", "command": "npx prettier --write ${file} && npx eslint --fix ${file}" }
    ]
  },
  "model": "claude-sonnet-4-6"
}
